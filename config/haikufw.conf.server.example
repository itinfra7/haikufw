default_inbound = deny

# loopback
allow tcp from 127.0.0.1/32 to port 1-65535
allow udp from 127.0.0.1/32 to port 1-65535

# management SSH
allow tcp from 203.0.113.0/24 to port 22
allow tcp from 2001:db8:100::/64 to port 22

# public services
allow tcp from any to port 80,443
allow udp from any to port 53,123

# application range for a trusted IPv4 network
allow all from 198.51.100.0/24 to port 60000-61000

# mixed port selector for a trusted IPv6 network
allow all from 2001:db8:200::/64 to port 53,80,443,60000-61000
